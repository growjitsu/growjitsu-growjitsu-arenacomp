rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: featured_banners
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - image_url: string (required)
    //   - mobile_image_url: string (optional)
    //   - link: string (required)
    //   - title: string (optional)
    //   - display_time: number (optional)
    //   - is_active: boolean (required)
    //   - order: number (required)
    //   - created_at: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.admin == true ||
          (request.auth.token.email != null && 
           (request.auth.token.email.lower() == "admin@arenacomp.com.br" || 
            request.auth.token.email.lower() == "carlos.atila001@gmail.com" ||
            request.auth.token.email == "carlos.atila001@gmail.com"))
        );
    }

    function isValidBanner(data) {
      let requiredFields = ['image_url', 'link', 'is_active', 'order'];
      return data.keys().hasAll(requiredFields);
    }

    function isValidUser(data) {
      return !('tipo' in data) || (data.tipo in ['atleta', 'nao_atleta']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /featured_banners/{bannerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBanner(request.resource.data);
      allow delete: if isAdmin();
    }

    match /arena_ads/{adId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total_impressions', 'total_clicks']));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
    }

    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
