rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: featured_banners
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - image_url: string (required)
    //   - mobile_image_url: string (optional)
    //   - link: string (required)
    //   - title: string (optional)
    //   - display_time: number (optional)
    //   - is_active: boolean (required)
    //   - order: number (required)
    //   - created_at: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.admin == true ||
          (request.auth.token.email != null && 
           (request.auth.token.email.lower() == "admin@arenacomp.com.br" || 
            request.auth.token.email.lower() == "carlos.atila001@gmail.com"))
        ); // Admin emails + Custom Claim
    }

    function isValidBanner(data) {
      let requiredFields = ['image_url', 'link', 'is_active', 'order'];
      let allowedFields = ['image_url', 'mobile_image_url', 'link', 'title', 'display_time', 'is_active', 'order', 'start_date', 'end_date', 'created_at', 'updated_at', 'country', 'state', 'city'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.image_url is string && data.image_url.size() < 5000 &&
             data.link is string && data.link.size() < 2000 &&
             data.is_active is bool &&
             data.order is number &&
             (!('title' in data) || data.title is string) &&
             (!('display_time' in data) || data.display_time is number) &&
             (!('mobile_image_url' in data) || data.mobile_image_url is string) &&
             (!('start_date' in data) || data.start_date is timestamp || data.start_date == null) &&
             (!('end_date' in data) || data.end_date is timestamp || data.end_date == null) &&
             (!('country' in data) || data.country is string) &&
             (!('state' in data) || data.state is string) &&
             (!('city' in data) || data.city is string);
    }

    function isValidLog(data) {
      let requiredFields = ['action', 'target_type', 'target_id', 'admin_id', 'created_at'];
      return data.keys().hasAll(requiredFields) &&
             data.action is string &&
             data.target_type is string &&
             data.target_id is string &&
             data.admin_id is string &&
             data.created_at is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /featured_banners/{bannerId} {
      allow read: if true; // Publicly readable for the landing page
      allow create, update, delete: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false; // Logs are immutable
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
