{
  "entities": {
    "featured_banner": {
      "title": "Featured Banner",
      "description": "A banner displayed on the landing page for sponsorship.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "image_url": { "type": "string" },
        "mobile_image_url": { "type": "string" },
        "link": { "type": "string" },
        "title": { "type": "string" },
        "display_time": { "type": "number" },
        "is_active": { "type": "boolean" },
        "order": { "type": "number" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "country_id": { "type": "string" },
        "state_id": { "type": "string" },
        "city_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["image_url", "link", "is_active", "order"]
    },
    "admin_log": {
      "title": "Admin Log",
      "description": "Logs of actions performed by administrators.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "admin_id": { "type": "string" },
        "admin_name": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["admin_id", "admin_name", "action", "timestamp"]
    },
    "user": {
      "title": "User Profile",
      "description": "User profile data for mandatory completion check.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "email_verified": { "type": "boolean" },
        "modalidades": { "type": "array", "items": { "type": "string" } },
        "equipe": { "type": "string" },
        "genero": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "graduacao": { "type": "string" },
        "academia": { "type": "string" },
        "pais": { "type": "string" },
        "estado": { "type": "string" },
        "cidade": { "type": "string" },
        "foto": { "type": "string" },
        "tipo": { "type": "string", "enum": ["atleta", "nao_atleta"] }
      }
    },
    "arena_ad": {
      "title": "Arena Ad",
      "description": "An advertisement displayed in various parts of the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "media_url": { "type": "string" },
        "link_url": { "type": "string" },
        "placement": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" },
        "total_impressions": { "type": "number" },
        "total_clicks": { "type": "number" },
        "landing_enabled": { "type": "boolean" },
        "landing_title": { "type": "string" },
        "landing_description": { "type": "string" },
        "landing_image": { "type": "string" },
        "landing_cta_text": { "type": "string" },
        "landing_cta_url": { "type": "string" },
        "landing_layout": { "type": "string", "enum": ["simple", "highlight", "premium"] }
      }
    },
    "email_settings": {
      "title": "Email Settings",
      "description": "SMTP configuration for the admin panel.",
      "type": "object",
      "properties": {
        "smtp_host": { "type": "string" },
        "smtp_port": { "type": "number" },
        "smtp_user": { "type": "string" },
        "smtp_password": { "type": "string" },
        "smtp_from_email": { "type": "string" },
        "smtp_from_name": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "email_verification": {
      "title": "Email Verification",
      "description": "Token for email verification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "email": { "type": "string" },
        "token": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "used": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/featured_banners/{bannerId}": {
      "schema": "featured_banner",
      "description": "Collection of featured banners for the landing page."
    },
    "/admin_logs/{logId}": {
      "schema": "admin_log",
      "description": "Collection of administrative action logs."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles for mandatory completion check."
    },
    "/arena_ads/{adId}": {
      "schema": "arena_ad",
      "description": "Collection of advertisements and landing pages."
    },
    "/settings/email": {
      "schema": "email_settings",
      "description": "Global SMTP settings singleton."
    },
    "/email_verifications/{token}": {
      "schema": "email_verification",
      "description": "Collection of verification tokens."
    }
  }
}
